# ============================================
# SmartOffice Backend - Переменные окружения
# ============================================

# База данных
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/smartoffice

# Безопасность
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Приложение
APP_NAME=SmartOffice API
APP_VERSION=1.0.0
DEBUG=true

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Логирование
LOG_LEVEL=INFO
LOG_FORMAT=console  # json или console
LOG_FILE=logs/app.log
