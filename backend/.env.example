# ============================================
# SmartOffice Backend - Переменные окружения
# ============================================

# База данных
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/smartoffice

# Безопасность
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Приложение
APP_NAME=SmartOffice API
APP_VERSION=1.0.0
DEBUG=true

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Логирование
LOG_LEVEL=INFO
LOG_FORMAT=console  # json или console
LOG_FILE=logs/app.log

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
FROM_EMAIL=noreply@smartoffice.com
FROM_NAME=SmartOffice
EMAIL_DEBUG=true  # True для логирования вместо отправки

# Sentry (мониторинг ошибок)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ERRORS_SAMPLE_RATE=1.0

# SAML SSO
SAML_SP_ENTITY_ID=https://smartoffice.local/saml/metadata
SAML_ACS_URL=https://smartoffice.local/api/auth/saml/acs
SAML_SLS_URL=https://smartoffice.local/api/auth/saml/sls
SAML_IDP_ENTITY_ID=
SAML_IDP_SSO_URL=
SAML_IDP_SLO_URL=
SAML_IDP_CERT=
SAML_SP_PRIVATE_KEY=
SAML_SP_CERT=
SAML_STRICT=true
SAML_DEBUG=false
