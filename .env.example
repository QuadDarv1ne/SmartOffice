# ============================================
# SmartOffice - Переменные окружения
# ============================================
# Скопируйте этот файл как .env и заполните значениями
# НИКОГДА не коммитьте файл .env в Git

# ============================================
# База данных (PostgreSQL)
# ============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=smartoffice
DATABASE_URL=postgresql+asyncpg://postgres:your-secure-password-here@localhost:5432/smartoffice

# ============================================
# Безопасность (Backend)
# ============================================
# Сгенерируйте ключ: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================
# Приложение (Backend)
# ============================================
APP_NAME=SmartOffice API
APP_VERSION=1.0.0
DEBUG=false

# ============================================
# CORS (Backend)
# ============================================
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ============================================
# Frontend
# ============================================
VITE_API_URL=http://localhost:8000/api
